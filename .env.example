NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-strong-secret
DATABASE_URL=postgresql://user:password@localhost:5432/db_name

YANDEX_CLIENT_ID=replace-with-yandex-client-id
YANDEX_CLIENT_SECRET=replace-with-yandex-client-secret

CAROUSEL_S3_BUCKET=replace-with-bucket-name
CAROUSEL_S3_REGION=us-east-1
CAROUSEL_S3_ENDPOINT=https://s3.example.com
CAROUSEL_S3_ACCESS_KEY_ID=replace-with-access-key
CAROUSEL_S3_SECRET_ACCESS_KEY=replace-with-secret-key
CAROUSEL_S3_FORCE_PATH_STYLE=false
CAROUSEL_CDN_URL=https://cdn.example.com
